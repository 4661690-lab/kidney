{
  "routes": [
    { "src": "/happy", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/happy.html" },
    { "src": "/happy", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/happy.html" },
    { "src": "/", "has": [{ "type": "host", "value": "zadiraka.cc" }], "status": 308, "headers": { "Location": "/happy" } },
    { "src": "/", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "status": 308, "headers": { "Location": "/happy" } },
    { "src": "/(.*)", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/zadiraka/index.html" },
    { "src": "/(.*)", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/zadiraka/index.html" },
    { "handle": "filesystem" },
    { "src": "/privacy", "dest": "/privacy.html" }
  ]
}
