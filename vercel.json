{
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/happy", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/happy.html" },
    { "src": "/happy", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/happy.html" },
    { "src": "/uahappy", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/uahappy.html" },
    { "src": "/uahappy", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/uahappy.html" },
    { "src": "/terms", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/terms.html" },
    { "src": "/terms", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/terms.html" },
    { "src": "/success", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/success.html" },
    { "src": "/success", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/success.html" },
    { "src": "/fail", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/fail.html" },
    { "src": "/fail", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/fail.html" },
    { "src": "/", "has": [{ "type": "host", "value": "zadiraka.cc" }], "status": 308, "headers": { "Location": "/happy" } },
    { "src": "/", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "status": 308, "headers": { "Location": "/happy" } },
    { "src": "/(.*)", "has": [{ "type": "host", "value": "zadiraka.cc" }], "dest": "/zadiraka/index.html" },
    { "src": "/(.*)", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "dest": "/zadiraka/index.html" },
    { "handle": "filesystem" },
    { "src": "/privacy", "dest": "/privacy.html" }
  ]
