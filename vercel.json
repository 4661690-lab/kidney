{
  "rewrites": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "zadiraka.cc" }], "destination": "/zadiraka/index.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.zadiraka.cc" }], "destination": "/zadiraka/index.html" },
